        "FASTMCP_SERVER_AUTH_CLIENT_SECRET": "<auth0_client_secret>",
        "FASTMCP_SERVER_AUTH_BASE_URL": "<server_base_url>",
        "FASTMCP_SERVER_AUTH_AUDIENCE": "<auth_audience>",
        "FASTMCP_SERVER_AUTH_SCOPE": "<auth_scope>",
        "user_impersonation": true
    }
